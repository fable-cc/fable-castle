---
layout: null
sitemap: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% for page in site.pages %}
{% unless page.nav_exclude or page.sitemap == false or page.url contains '/assets/' %}
  <url>
    <loc>{{ site.url }}{{ page.url | remove: '.html' }}</loc>
    <lastmod>{{ page.modified | default: site.time | date: '%Y-%m-%d' }}</lastmod>
    <changefreq>{{ page.changefreq | default: 'monthly' }}</changefreq>
    <priority>{{ page.priority | default: '0.5' }}</priority>
  </url>
{% endunless %}
{% endfor %}
{% for post in site.posts %}
  <url>
    <loc>{{ site.url }}{{ post.url | remove: '.html' }}</loc>
    <lastmod>{{ post.modified | default: post.date | date: '%Y-%m-%d' }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
{% endfor %}
</urlset>